{
	"type": "module",
	"name": "paleui",
	"version": "0.1.0",
	"description": "Pale UI",
	"author": "https://ahme.dev",
	"license": "MIT",
	"homepage": "https://paleui.ahme.dev",
	"repository": {
		"type": "git",
		"url": "https://github.com/ahme-dev/paleui.git",
		"directory": "packages/paleui"
	},
	"keywords": [
		"paleui",
		"css",
		"ui",
		"front-end",
		"theme",
		"component library",
		"css library"
	],
	"scripts": {
		"dist": "sass src:lib && postcss lib/*.css --dir lib",
		"dev": "concurrently -n sass,postcss \"sass src:lib --watch\" \"postcss lib/*.css --dir lib --watch\""
	},
	"types": "module",
	"dependencies": {},
	"devDependencies": {
		"autoprefixer": "^10.4.21",
		"concurrently": "^9.1.2",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.1",
		"sass": "^1.89.2"
	}
}
