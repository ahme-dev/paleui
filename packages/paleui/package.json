{
	"type": "module",
	"name": "paleui",
	"version": "0.0.0-semantic-release",
	"description": "Pale UI",
	"author": "https://ahme.dev",
	"license": "MIT",
	"homepage": "https://paleui.ahme.dev",
	"repository": {
		"type": "git",
		"url": "https://github.com/ahme-dev/paleui.git",
		"directory": "packages/paleui"
	},
	"keywords": [
		"paleui",
		"css",
		"ui",
		"front-end",
		"theme",
		"component library",
		"css library"
	],
	"files": [
		"lib/**/*.css"
	],
	"exports": {
		"./lib/*": "./lib/*",
		"./lib/*.css": "./lib/*.css"
	},
	"scripts": {
		"build": "tsx src/generate-css.ts; postcss src/ui/*.css --base src/ui --dir lib",
		"dev": "concurrently \"tsx src/generate-css.ts --watch\" \"postcss src/ui/*.css --base src/ui --dir lib --watch\"",
		"prepack": "pnpm run build"
	},
	"devDependencies": {
		"@sebbo2002/semantic-release-jsr": "^3.2.1",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"autoprefixer": "^10.4.21",
		"concurrently": "^9.1.2",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.1",
		"postcss-preset-env": "^11.1.1",
		"semantic-release": "^25.0.3",
		"tsx": "^4.21.0"
	}
}
