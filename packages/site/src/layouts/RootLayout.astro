---
import "paleui/lib/all.css";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
	title?: string;
}

const { title = "PaleUI" } = Astro.props;
---

<!doctype html>
<html lang="en" data-paleui>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		<link rel="stylesheet" href="/global.css" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap"
			rel="stylesheet"
		/>

		<script type="module" src="/test-mode.js"></script>
	</head>

	<body data-htswap>
		<header>
			<nav>
				<a href="/">
					<img
						class="dark-invert"
						height="24"
						src="/logo.svg"
						alt="PaleUI Logo"
						aria-label="PaleUI Logo"
					/>
				</a>

				<ul>
					<li>
						<a href="/docs">Docs</a>
					</li>
					<li>
						<a href="/components">Components</a>
					</li>
				</ul>

				<span role="none"></span>

				<span role="separator"></span>

				<ThemeToggle />

				<a
					target="_blank"
					title="Star the repo!"
					aria-label="Star gitHub repository"
					href="https://github.com/ahme-dev/paleui"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="17"
						height="17"
						viewBox="0 0 32 32"
					>
						<path
							fill="currentColor"
							fill-rule="evenodd"
							d="M16 2a14 14 0 0 0-4.43 27.28c.7.13 1-.3 1-.67v-2.38c-3.89.84-4.71-1.88-4.71-1.88a3.7 3.7 0 0 0-1.62-2.05c-1.27-.86.1-.85.1-.85a2.94 2.94 0 0 1 2.14 1.45a3 3 0 0 0 4.08 1.16a2.93 2.93 0 0 1 .88-1.87c-3.1-.36-6.37-1.56-6.37-6.92a5.4 5.4 0 0 1 1.44-3.76a5 5 0 0 1 .14-3.7s1.17-.38 3.85 1.43a13.3 13.3 0 0 1 7 0c2.67-1.81 3.84-1.43 3.84-1.43a5 5 0 0 1 .14 3.7a5.4 5.4 0 0 1 1.44 3.76c0 5.38-3.27 6.56-6.39 6.91a3.33 3.33 0 0 1 .95 2.59v3.84c0 .46.25.81 1 .67A14 14 0 0 0 16 2"
						></path>
					</svg>
				</a>
			</nav>
		</header>

		<slot />
	</body>
</html>

<style>
	header {
		position: sticky;
		top: 0;
		background-color: var(--background);
		z-index: 4;
		padding: 1rem 1.5rem;
	}

	header a {
		text-decoration: none;
		color: inherit;
	}

	header > nav {
		display: flex;
		flex-direction: row;
		align-items: center;
		z-index: 4;
		gap: 1.5rem;
		font-size: 0.8rem;
	}

	header > nav ul {
		display: flex;
		flex-direction: row;
		align-items: center;
		width: 100%;
		gap: 1.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
		font-weight: 500;
		box-sizing: border-box;
	}

	header > nav li {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		margin: 0;
		box-sizing: border-box;
	}

	header > nav a {
		padding: 0;
		height: min-content;
		line-height: 1;
		margin: 0;
		box-sizing: border-box;
	}

	@media (max-width: 768px) {
		header {
			padding: 1rem;
		}

		header > nav {
			gap: 1rem;
			font-size: 0.75rem;
		}

		header > nav ul {
			gap: 1rem;
		}
	}
</style>
