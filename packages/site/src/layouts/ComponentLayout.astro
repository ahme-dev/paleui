---
import BaseLayout from "./BaseLayout.astro";

interface Props {
	title?: string;
}

const { title = "PaleUI" } = Astro.props;
---

<BaseLayout title={title}>
	<input type="checkbox" id="sidebar-toggle" />
	<label for="sidebar-toggle" id="sidebar-label" aria-label="Toggle navigation">
		<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
			<path fill="currentColor" d="M3 18h18v-2H3zm0-5h18v-2H3zm0-7v2h18V6z" />
		</svg>
	</label>

	<aside id="component-aside">
		<small>Components</small>
		<ul>
			<li>
				<a href="/components/accordion" swap-target="#component-display" swap-history="true"
					>Accordion</a
				>
			</li>
			<li>
				<a href="/components/alert" swap-target="#component-display" swap-history="true">Alert</a
				>
			</li>
			<li>
				<a href="/components/alert-dialog" swap-target="#component-display" swap-history="true"
					>Alert Dialog</a
				>
			</li>
			<li>
				<a href="/components/aspect-ratio" swap-target="#component-display" swap-history="true"
					>Aspect Ratio</a
				>
			</li>
			<li>
				<a href="/components/avatar" swap-target="#component-display" swap-history="true"
					>Avatar</a
				>
			</li>
			<li>
				<a href="/components/badge" swap-target="#component-display" swap-history="true">Badge</a
				>
			</li>
			<li>
				<a href="/components/breadcrumbs" swap-target="#component-display" swap-history="true"
					>Breadcrumbs</a
				>
			</li>
			<li>
				<a href="/components/button" swap-target="#component-display" swap-history="true"
					>Button</a
				>
			</li>
			<li>
				<a href="/components/card" swap-target="#component-display" swap-history="true">Card</a>
			</li>
			<li>
				<a href="/components/checkbox" swap-target="#component-display" swap-history="true"
					>Checkbox</a
				>
			</li>
			<li>
				<a href="/components/dialog" swap-target="#component-display" swap-history="true"
					>Dialog</a
				>
			</li>
			<li>
				<a href="/components/dropdown-menu" swap-target="#component-display" swap-history="true"
					>Dropdown Menu</a
				>
			</li>
			<li>
				<a href="/components/input" swap-target="#component-display" swap-history="true">Input</a
				>
			</li>
			<li>
				<a href="/components/select" swap-target="#component-display" swap-history="true"
					>Select</a
				>
			</li>
			<li>
				<a href="/components/separator" swap-target="#component-display" swap-history="true"
					>Separator</a
				>
			</li>
			<li>
				<a href="/components/tabs" swap-target="#component-display" swap-history="true">Tabs</a>
			</li>
		</ul>

		<small>Utilities</small>
	</aside>

	<section id="component-display">
		<slot />

		<small>
			Built by <a rel="noopener" target="_blank" href="https://ahme.dev">ahme.dev</a>. The source
			code is available on <a
				rel="noopener"
				target="_blank"
				href="https://github.com/ahme-dev/paleui/packages/paleui">Github</a
			>
		</small>
	</section>
</BaseLayout>

<style>
	#component-aside {
		padding: 0 1.5rem;
		display: flex;
		gap: calc(var(--spacing) * 2);
		flex-direction: column;
		position: sticky;
		top: 2rem;
		align-self: flex-start;
		max-height: 100vh;
		overflow-y: auto;
	}

	#component-aside small {
		list-style: none;
		display: inline-flex;
		flex-direction: column;
		font-weight: 500;
		gap: 0;
		padding: 0 0.5rem;
		margin-top: 3rem;
		color: var(--muted-foreground);
	}

	#component-aside ul {
		list-style: none;
		display: flex;
		flex-direction: column;
	}

	#component-aside ul li {
		box-sizing: border-box;
		line-height: 1;
		display: flex;
		flex-direction: column;
		border-radius: var(--radius);
		height: auto;
		width: fit-content;
	}

	#component-aside ul li:hover {
		background-color: var(--secondary);
	}

	#component-aside a {
		font-size: 0.875rem;
		font-weight: 500;
		box-sizing: border-box;
		text-wrap: nowrap;
		padding: 0.6rem;
		text-decoration: none;
		color: inherit;
	}

	#component-display {
		display: flex;
		flex-direction: column;
		max-width: 40rem;
		margin: 0 auto;
		width: 100%;
		box-sizing: border-box;
	}

	@media (max-width: 768px) {
		#component-display {
			padding: 0 1.5rem;
		}
	}

	#component-display a {
		color: inherit;
	}

	#component-display > small {
		margin-top: 2rem;
	}

	:global(.aspect) {
		border: 1px solid var(--border);
		background-color: var(--muted);
		font-size: 0.8rem;
		border-radius: var(--radius);
		padding: calc(var(--spacing) * 2);
		text-align: center;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	#sidebar-toggle {
		display: none;
	}

	#sidebar-label {
		display: none;
		position: fixed;
		top: 4rem;
		right: 1rem;
		z-index: 1000;
		background-color: var(--secondary);
		color: var(--secondary-foreground);
		box-shadow: var(--shadow-xs);
		border-radius: var(--radius-md);
		width: 2.5rem;
		height: 2.5rem;
		cursor: pointer;
		align-items: center;
		justify-content: center;
		transition: transform 0.3s ease;
	}

	#sidebar-label svg {
		width: 1rem;
		height: 1rem;
	}

	@media (max-width: 768px) {
		#sidebar-label {
			display: flex;
		}

		#component-aside {
			position: fixed;
			top: 0;
			left: -100%;
			width: 280px;
			max-width: 80vw;
			height: 100vh;
			max-height: 100vh;
			overflow-y: auto;
			overflow-x: hidden;
			background-color: var(--background);
			border-right: 1px solid var(--border);
			z-index: 999;
			transition: left 0.3s ease;
			padding: 1rem 1.5rem;
			-webkit-overflow-scrolling: touch;
		}

		#sidebar-toggle:checked ~ #component-aside {
			left: 0;
		}
	}
</style>
