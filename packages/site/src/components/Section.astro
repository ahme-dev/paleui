---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<section>
	<h2>{title}</h2>

	<slot />
</section>

<style>
	section {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding-top: 3rem;
	}

	@media (max-width: 768px) {
		section {
			padding-top: 2.5rem;
		}
	}
</style>
