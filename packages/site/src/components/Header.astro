---
import CodeExample from "./CodeExample.astro";

interface Props {
	title: string;
	subtitle: string;
	links: {
		title: string;
		url: string;
	}[];
}

const { title, subtitle, links } = Astro.props;
---

<section>
	<hgroup>
		<h1>{title}</h1>
		<p class="lead subtitle">{subtitle}</p>
	</hgroup>

	{
		links.length > 0 && (
			<div class="links">
				{links.map((el) => (
					<div role="status" class="secondary">
						<a target="_blank" rel="noopener noreferrer" href={el.url}>
							{el.title}
						</a>
					</div>
				))}
			</div>
		)
	}

	<CodeExample>
		<slot />
	</CodeExample>

	<div class="below">
		<slot name="below" />
	</div>
</section>

<style>
	section {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding-top: 2.5rem;
	}

	section hgroup {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.subtitle {
		margin: 0;
	}

	.links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
	}

	.links a {
		color: inherit;
		text-decoration: none;
	}

	@media (max-width: 768px) {
		section {
			padding-top: 2rem;
		}
	}

	.below {
		display: flex;
		flex-direction: column;
	}
</style>
