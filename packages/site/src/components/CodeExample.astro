---
interface Props {
	codeOnly?: boolean;
}

const { codeOnly = false } = Astro.props;
const slotHtml = await Astro.slots.render("default");

function formatHtml(html: string, indentSize: number = 2): string {
	const tokens = html.split(/(<[^>]+>)/g).filter((token) => token.trim());
	let indent = 0;
	const formatted: string[] = [];

	for (let i = 0; i < tokens.length; i++) {
		const token = tokens[i];

		// check if token is an html tag
		if (token.startsWith("<")) {
			const isClosing = token.startsWith("</");
			const isSelfClosing =
				token.endsWith("/>") ||
				token.match(
					/^<(area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)/i,
				);
			const isComment = token.startsWith("<!--");

			if (isClosing) {
				indent = Math.max(0, indent - 1);
				formatted.push(" ".repeat(indent * indentSize) + token);
			} else if (isSelfClosing || isComment) {
				formatted.push(" ".repeat(indent * indentSize) + token);
			} else {
				formatted.push(" ".repeat(indent * indentSize) + token);
				indent++;
			}
		} else {
			// text content - trim and add if not empty
			const trimmed = token.trim();
			if (trimmed) {
				formatted.push(" ".repeat(indent * indentSize) + trimmed);
			}
		}
	}

	return formatted.join("\n");
}

const formattedCode = formatHtml(slotHtml);

function escapeHtml(str: string): string {
	return str
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;")
		.replace(/"/g, "&quot;")
		.replace(/'/g, "&#039;");
}

const escapedCode = escapeHtml(formattedCode);
---

<div class="example" data-code-example>
	{
		!codeOnly && (
			<div class="preview-panel max">
				<slot />
			</div>
		)
	}

	<div class="code-panel" data-expandable data-state="collapsed">
		<span class="overlay overlay-dim" aria-hidden="true"></span>
		<span class="overlay overlay-fade" aria-hidden="true"></span>
		<pre><code set:html={escapedCode} /></pre>
		<button
			type="button"
			class="icon outline copy-btn"
			aria-label="Copy to clipboard"
			title="Copy to clipboard"
			data-code={formattedCode}>&#x2398;</button
		>
		<button
			type="button"
			class="outline"
			aria-label="Expand code"
			aria-expanded="false"
			data-expand>View code</button
		>
	</div>
</div>

<style>
	.example {
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
	}

	.preview-panel {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 2rem;
		padding: 4rem 1rem;
		max-width: 400px;
		margin: 0 auto;
		aspect-ratio: 9 / 5;
	}

	.preview-panel :global([data-dimension]) {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		width: 100%;
	}

	.preview-panel :global([data-header]) {
		display: grid;
		align-items: start;
		justify-items: center;
		width: 100%;
	}

	.preview-panel :global([data-example]) {
		display: grid;
		align-items: start;
		justify-items: center;
	}

	.preview-panel :global([data-header] > [data-accordion]),
	.preview-panel :global([data-header] > article),
	.preview-panel :global([data-header] > [role="alert"]),
	.preview-panel :global([data-header] > [data-typography]),
	.preview-panel :global([data-example] > [data-accordion]),
	.preview-panel :global([data-example] > article),
	.preview-panel :global([data-example] > [role="alert"]),
	.preview-panel :global([data-example] > [data-typography]) {
		width: 100%;
	}

	.example:not(:has(.preview-panel)) .code-panel {
		border-radius: var(--radius);
	}

	.code-panel {
		--code-panel-collapsed-height: 192px;
		position: relative;
		background: var(--muted);
		padding: 1rem;
		border-top: 1px solid var(--border);
	}

	.code-panel pre {
		margin: 0;
		width: auto;
		overflow: auto;
		overscroll-behavior: contain;
		border: 0;
		border-radius: 0;
		background: transparent;
	}

	.code-panel[data-state="collapsed"] pre {
		max-height: var(--code-panel-collapsed-height);
		overflow: hidden;
	}

	.code-panel pre > code {
		min-width: 0;
		padding: 0;
	}

	.code-panel[data-state="expanded"] pre {
		max-height: min(60rem, calc(100vh - 14rem));
	}

	.code-panel code {
		padding: 0;
		border-radius: 0;
		background: transparent;
		font-family: var(--font-mono, ui-monospace, monospace);
		color: var(--color-foreground);
		font-size: 0.875rem;
		font-weight: 400;
		line-height: 1.5;
		white-space: pre;
	}

	.code-panel .copy-btn {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		cursor: pointer;
	}

	.code-panel [data-expand] {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		cursor: pointer;
		z-index: 2;
	}

	.code-panel[data-state="collapsed"] .overlay {
		display: block;
		position: absolute;
		pointer-events: none;
		z-index: 1;
	}

	.code-panel[data-state="collapsed"] .overlay-dim {
		inset: 0;
		background-color: var(--muted);
		opacity: 0.5;
	}

	.code-panel[data-state="collapsed"] .overlay-fade {
		left: 1rem;
		right: 1rem;
		bottom: 0;
		height: 6rem;
		background: linear-gradient(
			to bottom,
			transparent 0%,
			var(--muted) 70%,
			var(--muted) 100%
		);
	}

	.code-panel[data-state="expanded"] .overlay,
	.code-panel[data-state="static"] .overlay {
		display: none;
	}

	.code-panel[data-collapsible="false"] [data-expand] {
		display: none;
	}

	.code-panel [data-expand][hidden] {
		display: none;
	}
</style>

<script>
	const CODE_PANEL_SELECTOR = "[data-expandable]";

	function getCollapsedHeight(panel) {
		const height = Number.parseFloat(
			getComputedStyle(panel)
				.getPropertyValue("--code-panel-collapsed-height")
				.trim(),
		);
		return Number.isFinite(height) ? height : 192;
	}

	function updateExpandButton(panel, btn) {
		const collapsible = panel.getAttribute("data-collapsible") === "true";
		const expanded = panel.getAttribute("data-state") === "expanded";

		btn.hidden = !collapsible || expanded;
		btn.setAttribute("aria-expanded", collapsible ? String(expanded) : "false");
		btn.setAttribute("aria-label", "Expand code");
		btn.textContent = "View code";
	}

	function syncCodePanel(panel) {
		const pre = panel.querySelector("pre");
		const btn = panel.querySelector("[data-expand]");
		if (!(pre instanceof HTMLElement) || !(btn instanceof HTMLButtonElement)) {
			return;
		}

		const needsCollapse = pre.scrollHeight > getCollapsedHeight(panel) + 1;
		const state = panel.getAttribute("data-state");

		panel.setAttribute("data-collapsible", needsCollapse ? "true" : "false");

		if (!needsCollapse) {
			panel.setAttribute("data-state", "static");
		} else if (state !== "collapsed" && state !== "expanded") {
			panel.setAttribute("data-state", "collapsed");
		}

		updateExpandButton(panel, btn);
	}

	function syncCodePanels() {
		document
			.querySelectorAll(CODE_PANEL_SELECTOR)
			.forEach((panel) => syncCodePanel(panel));
	}

	// copy functionality
	document
		.querySelectorAll<HTMLButtonElement>(".copy-btn[data-code]")
		.forEach((btn) => {
			if (btn.dataset.bound === "true") return;
			btn.dataset.bound = "true";

			btn.addEventListener("click", () => {
				const code = btn.getAttribute("data-code") || "";
				navigator.clipboard
					.writeText(code)
					.then(() => {
						btn.textContent = "\u2714";
						setTimeout(() => {
							btn.textContent = "\u2398";
						}, 2000);
					})
					.catch(() => {
						btn.textContent = "\u2718";
						setTimeout(() => {
							btn.textContent = "\u2398";
						}, 2000);
					});
			});
		});

	// expand/collapse functionality
	document
		.querySelectorAll<HTMLButtonElement>("[data-expand]")
		.forEach((btn) => {
			if (btn.dataset.bound === "true") return;
			btn.dataset.bound = "true";

			btn.addEventListener("click", () => {
				const panel = btn.closest<HTMLElement>("[data-expandable]");
				if (!panel) return;
				if (panel.getAttribute("data-collapsible") !== "true") return;
				if (panel.getAttribute("data-state") === "expanded") return;

				panel.setAttribute("data-state", "expanded");
				updateExpandButton(panel, btn);
			});
		});

	syncCodePanels();
	window.addEventListener("load", syncCodePanels, { once: true });
	window.addEventListener("resize", syncCodePanels);
</script>
