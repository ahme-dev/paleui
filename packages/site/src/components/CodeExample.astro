---
interface Props {
	codeOnly?: boolean;
}

const { codeOnly = false } = Astro.props;
const slotHtml = await Astro.slots.render("default");

function formatHtml(html: string, indentSize: number = 2): string {
	const tokens = html.split(/(<[^>]+>)/g).filter((token) => token.trim());
	let indent = 0;
	const formatted: string[] = [];

	for (let i = 0; i < tokens.length; i++) {
		const token = tokens[i];

		// check if token is an html tag
		if (token.startsWith("<")) {
			const isClosing = token.startsWith("</");
			const isSelfClosing =
				token.endsWith("/>") ||
				token.match(
					/^<(area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)/i,
				);
			const isComment = token.startsWith("<!--");

			if (isClosing) {
				indent = Math.max(0, indent - 1);
				formatted.push(" ".repeat(indent * indentSize) + token);
			} else if (isSelfClosing || isComment) {
				formatted.push(" ".repeat(indent * indentSize) + token);
			} else {
				formatted.push(" ".repeat(indent * indentSize) + token);
				indent++;
			}
		} else {
			// text content - trim and add if not empty
			const trimmed = token.trim();
			if (trimmed) {
				formatted.push(" ".repeat(indent * indentSize) + trimmed);
			}
		}
	}

	return formatted.join("\n");
}

const formattedCode = formatHtml(slotHtml);

function escapeHtml(str: string): string {
	return str
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;")
		.replace(/"/g, "&quot;")
		.replace(/'/g, "&#039;");
}

const escapedCode = escapeHtml(formattedCode);
---

<div class="example">
	{
		!codeOnly && (
			<div class="preview-panel max">
				<slot />
			</div>
		)
	}

	<div class="code-panel" data-expandable data-state="collapsed">
		<span class="overlay"></span>
		<pre><code set:html={escapedCode} /></pre>
		<button
			type="button"
			class="icon outline copy-btn"
			aria-label="Copy to clipboard"
			title="Copy to clipboard"
			data-code={formattedCode}>&#x2398;</button
		>
		<button
			type="button"
			class="outline"
			aria-label="Expand code"
			aria-expanded="false"
			data-expand>View code</button
		>
	</div>
</div>

<style>
	.example {
		border: 1px solid var(--border);
		margin-top: 1rem;
		border-radius: var(--radius);
		overflow: hidden;
	}

	.preview-panel {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 2rem;
		padding: 4rem 1rem;
		max-width: 400px;
		margin: 0 auto;
		aspect-ratio: 9 / 5;
	}

	.example:not(:has(.preview-panel)) .code-panel {
		border-radius: var(--radius);
	}

	.code-panel {
		position: relative;
		background: var(--muted);
		padding: 1rem;
		max-height: 12rem;
		border-top: 1px solid var(--border);
		overflow: hidden;
		transition: max-height 0.3s ease;
	}

	.code-panel[data-state="expanded"] {
		max-height: 60rem;
	}

	.code-panel pre {
		margin: 0;
		overflow-x: auto;
	}

	.code-panel[data-state="expanded"] pre {
		max-height: calc(60rem - 2rem);
		overflow-y: auto;
	}

	.code-panel code {
		font-family: var(--font-mono, ui-monospace, monospace);
		color: var(--color-foreground);
		font-size: 0.875rem;
		line-height: 1.5;
		white-space: pre;
	}

	.code-panel .copy-btn {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		cursor: pointer;
	}

	.code-panel [data-expand] {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translateX(-50%) translateY(-50%);
		cursor: pointer;
		transition: transform 0.3s ease;
	}

	.code-panel[data-state="collapsed"] .overlay {
		display: block;
		position: absolute;
		left: 0;
		width: 100%;
		height: 100%;
		background-color: var(--muted);
		opacity: 0.5;
		pointer-events: none;
	}

	.code-panel[data-state="expanded"] .overlay {
		display: none;
	}

	.code-panel[data-state="expanded"] [data-expand] {
		display: none;
	}
</style>

<script>
	// copy functionality
	document
		.querySelectorAll<HTMLButtonElement>(".copy-btn[data-code]")
		.forEach((btn) => {
			btn.addEventListener("click", () => {
				const code = btn.getAttribute("data-code") || "";
				navigator.clipboard
					.writeText(code)
					.then(() => {
						btn.textContent = "\u2714";
						setTimeout(() => {
							btn.textContent = "\u2398";
						}, 2000);
					})
					.catch(() => {
						btn.textContent = "\u2718";
						setTimeout(() => {
							btn.textContent = "\u2398";
						}, 2000);
					});
			});
		});

	// expand/collapse functionality
	document.querySelectorAll<HTMLElement>("[data-expand]").forEach((btn) => {
		btn.addEventListener("click", () => {
			const panel = btn.closest<HTMLElement>("[data-expandable]");
			if (!panel) return;

			const isExpanded = panel.getAttribute("data-state") === "expanded";
			const newState = !isExpanded;

			panel.setAttribute("data-state", newState ? "expanded" : "collapsed");
			btn.setAttribute("aria-expanded", String(newState));
			btn.setAttribute(
				"aria-label",
				newState ? "Collapse code" : "Expand code",
			);
		});
	});
</script>
