---
import CodeExample from "./CodeExample.astro";

interface Props {
	title?: string;
	subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

{title && (
	<>
		<h3 id={title}>{title}</h3>
		{subtitle && <p>{subtitle}</p>}
	</>
)}

<slot name="above" />

<CodeExample name="subsection" class="flex-col gap">
	<slot />
</CodeExample>

<slot name="below" />

<style>
	h3 {
		font-weight: 500;
		font-size: 1.15rem;
		margin-top: 2rem;
		margin-bottom: 1.5rem;
	}
</style>