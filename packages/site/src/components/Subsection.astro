---
import CodeExample from "./CodeExample.astro";

interface Props {
	title?: string;
	subtitle?: string;
	codeOnly?: boolean;
}

const { title, subtitle, codeOnly = false } = Astro.props;
---

<section class:list={["subsection", title && "with-heading"]}>
	{
		title && (
			<>
				<h3 id={title}>{title}</h3>
				{subtitle && <p class="muted subtitle">{subtitle}</p>}
			</>
		)
	}

	<div class="above">
		<slot name="above" />
	</div>

	<CodeExample codeOnly={codeOnly}>
		<slot />
	</CodeExample>

	<slot name="below" />
</section>

<style>
	.subsection {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.subsection.with-heading {
		padding-top: 2rem;
	}

	.subtitle {
		margin: 0;
	}

	.above {
		display: flex;
		flex-direction: column;
	}

	.above:empty {
		display: none;
	}
</style>
