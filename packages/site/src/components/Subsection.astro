---
import CodeExample from "./CodeExample.astro";

interface Props {
	title?: string;
	subtitle?: string;
	codeOnly?: boolean;
}

const { title, subtitle, codeOnly = false } = Astro.props;
---

{
	title && (
		<>
			<h3 id={title}>{title}</h3>
			{subtitle && <p>{subtitle}</p>}
		</>
	)
}

<div class="above">
	<slot name="above" />
</div>

<CodeExample codeOnly={codeOnly}>
	<slot />
</CodeExample>

<slot name="below" />

<style>
	h3 {
		font-weight: 500;
		font-size: 1.15rem;
		margin-top: 2rem;
	}
	p {
		margin-top: 0.25rem;
		margin-bottom: 0.25rem;
	}
	.above {
		margin-top: 0.75rem;
		margin-bottom: 1rem;
	}
	.above :global(p + p) {
		margin-top: 0.5rem;
	}
</style>
