---
import RootLayout from "@/layouts/RootLayout.astro";
import ThemePlayground from "@/components/ThemePlayground.astro";
---

<RootLayout title="PaleUI">
	<main class="landing">
		<section class="hero" aria-labelledby="landing-title">
			<div class="hero-copy">
				<hgroup class="hero-head">
					<h1 id="landing-title">Semantic UI primitives with a familiar theme model.</h1>
					<p class="lead">
						PaleUI gives you plain HTML components styled with CSS variables, so shadcn-style
						themes work without bringing along a JS component runtime.
					</p>
				</hgroup>

				<div class="hero-actions">
					<a class="button" href="/docs">Read the Docs</a>
					<a class="button ghost" href="/components/accordion">Browse Components</a>
					<a class="button outline" href="#theme-playground-title">Try a Theme</a>
				</div>
			</div>
		</section>

		<ThemePlayground />

		<footer class="page-foot">
			<a href="https://github.com/ahme-dev/paleui" class="muted">
				SOURCE CODE
			</p>
		</footer>
	</main>
</RootLayout>

<style>
	.landing {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		max-width: 72rem;
		margin: 0 auto;
		padding: 2.5rem 1.25rem 3rem;
		box-sizing: border-box;
	}

	.hero {
		padding: 4rem 0 3.5rem;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.hero-copy {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		max-width: 40rem;
		align-items: center;
		text-align: center;
	}

	.hero-head {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
	}

	.hero h1 {
		font-size: clamp(2.75rem, 6vw, 4.5rem);
		line-height: 0.98;
		letter-spacing: -0.04em;
		max-width: 15ch;
		margin: 0 auto;
	}

	.hero-head .lead {
		max-width: 34rem;
		margin: 0 auto;
	}

	.page-foot {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		font-family: monospace;
		gap: 1rem 1.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border);
		text-align: center;
	}

	.page-foot p {
		margin: 0;
		max-width: 36rem;
	}

	.foot-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1rem;
	}

	.foot-links a {
		color: inherit;
		text-decoration: none;
	}

	@media (max-width: 768px) {
		.landing {
			padding: 2rem 1rem 3rem;
		}

		.hero {
			padding: 3rem 0 2.75rem;
		}

		.hero h1 {
			font-size: 2.5rem;
		}

		.page-foot {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
