---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="PaleUI">
	<div id="landing">
		<section>
			<hgroup>
				<h1>PaleUI</h1>
				<p>
					The sleek design of <strong>shadcn/ui</strong>, with 0 JavaScript.
					<br />
					Build beautiful and responsive user interfaces with ease.
				</p>
			</hgroup>

			<div>
				<button>Get Started</button>

				<a role="button" class="ghost" href="/components/button">Browse Components</a>
			</div>
		</section>

		<section>
			<hgroup>
				<h2>Features</h2>
				<p>A list of features.</p>
			</hgroup>

			<ul>
				<li>To</li>
				<li>Be</li>
				<li>Added</li>
			</ul>
		</section>
	</div>
</BaseLayout>

<style>
	#landing {
		max-width: 700px;
		margin: 0 auto;
	}

	#landing section {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 80vh;
		gap: 1rem;
	}

	#landing hgroup {
		text-align: center;
	}

	#landing h1 {
		font-size: 3rem;
		margin: 0;
	}
</style>
