---
import RootLayout from "@/layouts/RootLayout.astro";
---

<RootLayout title="PaleUI">
	<section>
		<img
			height="200"
			src="/logo.svg"
			alt="PaleUI Logo"
			aria-label="PaleUI Logo"
		/>

		<hgroup>
			<h1>PaleUI</h1>
			<p>
				The sleek design of <strong>shadcn/ui</strong>, with 0 JavaScript.
				<br />
				Build beautiful and responsive user interfaces with ease.
			</p>
		</hgroup>

		<div>
			<button>Get Started</button>

			<a class="button ghost" href="/components/accordion"
				>View Components</a
			>
		</div>
	</section>
</RootLayout>

<style>
	section {
		max-width: 40rem;
		margin: 0 auto;

		min-height: 85vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
	}

	hgroup {
		text-align: center;
	}

	hgroup h1 {
		font-size: 3rem;
		margin: 0;
	}
</style>
