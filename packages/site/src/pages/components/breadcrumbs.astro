<SideLayout title="Breadcrumbs - PaleUI">
	<Header
		title="Breadcrumbs"
		subtitle="Displays the path to the current resource using a hierarchy of links."
		links={[]}
	>
		<nav aria-label="breadcrumb">
			<ol style="--separator: '/'">
				<li><a href="#">Home</a></li><li><a href="#">Products</a></li><li>
					<a href="#">Laptops</a>
				</li><li aria-current="page">Gaming Laptop</li>
			</ol>
		</nav>
	</Header>
	<Section title="Structure"
		><Subsection
			><Fragment slot="above"
				><p>
					Breadcrumbs are made using a <code>&lt;nav&gt;</code> element with <code
						>aria-label="breadcrumb"</code
					> containing an ordered list (<code>&lt;ol&gt;</code>) of links. The
					current page is indicated with <code>aria-current="page"</code> and should
					not be a link.
				</p><p><code>ol</code> — Ordered list of breadcrumb items.</p><p>
					<code>li</code> — Breadcrumb item.
				</p><p><code>a</code> — Breadcrumb link (optional).</p></Fragment
			><nav aria-label="breadcrumb">
				<ol>
					<li>
						<a href="/">
							<!-- breadcrumb 1 -->
						</a>
					</li>
					<!-- other breadcrumbs -->
				</ol>
			</nav></Subsection
		></Section
	><Section title="Examples"
		><Subsection title="Separators"
			><Fragment slot="above"
				><p>
					By default, ">" is used as the separator. But this can be changed by
					overriding the <code>--separator</code> CSS variable.
				</p></Fragment
			><nav aria-label="breadcrumb">
				<ol style="--separator: '/'">
					<li><a href="#">Home</a></li><li><a href="#">Products</a></li><li>
						<a href="#">Laptops</a>
					</li><li aria-current="page">Gaming Laptop</li>
				</ol>
			</nav></Subsection
		><Subsection title="Icons"
			><Fragment slot="above"
				><p>
					A <code>&lt;svg&gt;</code> element can be added inside the breadcrumb item
					link.
				</p></Fragment
			><nav aria-label="breadcrumb">
				<ol>
					<li><a href="#">Home</a></li><li><a href="#">Projects</a></li><li>
						<a href="#"
							><svg
								xmlns="http://www.w3.org/2000/svg"
								width="32"
								height="32"
								viewBox="0 0 32 32"
								><path
									fill="currentColor"
									d="m16 2l-4.55 9.22l-10.17 1.47l7.36 7.18L6.9 30l9.1-4.78L25.1 30l-1.74-10.13l7.36-7.17l-10.17-1.48Z"
								></path></svg
							> Favourites</a>
					</li><li aria-current="page">Settings</li>
				</ol>
			</nav></Subsection
		><Subsection title="Collapsed"
			><Fragment slot="above"
				><p>
					For very long breadcrumb trails, you can show an ellipsis to indicate
					collapsed items.
				</p><p>
					Instead of a link, the collapsed item can be represented by a span
					with <code>aria-hidden="true"</code>. The attribute is there to
					indicate that the item is not part of the navigation and should not be
					announced by screen readers.
				</p></Fragment
			><nav aria-label="breadcrumb">
				<ol>
					<li><a href="#">Home</a></li><li>
						<span aria-hidden="true">...</span>
					</li><li><a href="#">Components</a></li><li>
						<a href="#">Navigation</a>
					</li><li aria-current="page">Breadcrumbs</li>
				</ol>
			</nav></Subsection
		></Section
	>
</SideLayout>
